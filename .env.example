# local-ai-lab configuration. Copy to .env and edit. All values are optional;
# the defaults run out of the box with the Claude Code CLI + BM25 retrieval.

# --- Which AI answers questions: claude | ollama | gemini | openai ---
RAG_PROVIDER=claude

# --- Retrieval engine: bm25 (default, zero setup) | embeddings (semantic) ---
RAG_RETRIEVER=bm25

# When RAG_RETRIEVER=embeddings, which provider produces the vectors.
# Claude Code cannot embed, so embeddings need ollama | gemini | openai.
RAG_EMBED_PROVIDER=ollama

# Folder you drop PDF / DOCX / TXT / MD files into.
RAG_DOCS_DIR=documents

# How many chunks to feed the model as grounding context.
RAG_TOP_K=5

# --- Links shown in the web UI footer (course / author) ---
LINKEDIN_URL=https://www.linkedin.com/in/nikolareljin
GITHUB_URL=https://github.com/nikolareljin/local-ai-lab
TUTORIAL_URL=https://nikolareljin.github.io/local-ai-lab/

# Base URL of the docs site used for in-app "Troubleshooting" links. Defaults to
# the published GitHub Pages site. To preview your LOCAL docs edits before
# publishing, serve docs/ and point this at it, e.g.:
#   python3 -m http.server 8000 --directory docs   # then open localhost:8000
#   DOCS_BASE_URL=http://localhost:8000/
DOCS_BASE_URL=https://nikolareljin.github.io/local-ai-lab/

# --- Claude Code (default) ---
# Uses your existing `claude` CLI login; no API key needed.
CLAUDE_BIN=claude

# --- Ollama (local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- OpenAI (or any OpenAI-compatible endpoint) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

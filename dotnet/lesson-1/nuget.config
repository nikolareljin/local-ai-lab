<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Use only nuget.org for this teaching project so a private mirror's
         downtime never blocks the restore. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>

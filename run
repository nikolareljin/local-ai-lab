#!/usr/bin/env bash
# SCRIPT: run
# DESCRIPTION: Run a local-ai-lab lesson locally.  Usage:  ./run -l <N> [action]
# DEFAULT AI: the Claude Code CLI (no API key needed). Override with RAG_PROVIDER.
# CREATOR: Nik Reljin
set -euo pipefail

source "$(dirname "$0")/scripts/include.sh"

# Diagnostics go to stderr: several actions (Lesson 2 `serve`, the language
# wrappers) exec an stdio MCP server whose stdout IS the JSON-RPC stream, so any
# [INFO] preamble on stdout would corrupt the handshake. Keep stdout clean for
# every action (the shared log_info writes to stdout).
log_info() { echo "[INFO] $*" >&2; }

usage() {
  cat <<'EOF'
local-ai-lab — run a lesson locally

Usage:
  ./run -l <N> [--lang python|node|csharp] [action] [args]
  ./run -l <N> show                           # walk through the lesson in the terminal (code, configs, prompts, commands)
  ./run -l <N> preview                        # serve the rendered instructions locally (browser, no GitHub Pages)
  ./run list                                  # list all lessons

Lessons:
  -l 1   RAG app       actions:  web (default) · ask "question" · repl · index · test
  -l 2   MCP server    actions:  demo (default) · serve · register · test
  -l 3+  config-driven: actions are defined per lesson in lessons/NN-*/lesson.json (run + show)

Examples:
  ./run -l 1                                  # launch the RAG web UI (auto-picks a free port)
  ./run -l 1 ask "How do I reset the device?" # one-shot question in the terminal
  ./run -l 1 test                             # run Lesson 1 tests
  ./run -l 2                                  # demo the MCP server end-to-end (no LLM needed)
  ./run -l 3                                  # run Lesson 3's default demo (Python)
  ./run -l 3 --lang csharp                    # the C#/.NET port of Lesson 3
  ./run -l 3 show                             # walk through Lesson 3's steps (terminal)
  ./run -l 3 preview                          # preview the instructions in a browser, locally
  ./run -l 3 show --html > /tmp/l3.html        # standalone HTML of the instructions
  ./run -l 1 --lang node                      # Node.js implementation (where ported)

Languages (polyglot — Option B): python (default/reference) · node · csharp.
Lessons 1 and 2 are ported to all three; where a lesson isn't ported yet,
  --lang node|csharp points you to the Python reference.

The default AI provider is the Claude Code CLI — no API key, it uses your existing
Claude Code login. Override anytime with  RAG_PROVIDER=ollama|gemini|openai.

Options:
  -l, --lesson N        which lesson (1, 2, or any lessons/NN-* lesson)
  --lang LANG           python | node | csharp  (default: python)
  -h, --help            show this help
EOF
}

# Announce the AI provider so it's obvious Claude Code is the default, and check it.
announce_provider() {
  local provider="${RAG_PROVIDER:-claude}"
  if [[ "$provider" == "claude" ]]; then
    if command -v "${CLAUDE_BIN:-claude}" >/dev/null 2>&1; then
      log_info "AI provider: Claude Code CLI (default — no API key needed)."
    else
      log_warn "Default AI is the Claude Code CLI, but '${CLAUDE_BIN:-claude}' is not on your PATH."
      log_warn "Install Claude Code (recommended), or set RAG_PROVIDER=ollama|gemini|openai."
    fi
  else
    log_info "AI provider: ${provider} (RAG_PROVIDER override; default is Claude Code)."
  fi
}

# List every lesson: Lessons 1-2 (bespoke) + the config-driven registry (3+).
list_lessons() {
  echo "Lessons:"
  echo "  L1   RAG from scratch                    [working]  (python, node, csharp)"
  echo "  L2   MCP servers                         [working]  (python, node, csharp)"
  "$PYTHON_BIN" "$ROOT_DIR/tools/lesson.py" list 2>/dev/null | sed 's/^/  /'
}

# --- parse a leading -l/--lesson flag, leave the rest as the action + args ---
LESSON=""
LANG_EXPLICIT=0
# need_value <remaining-arg-count> <option> <example>
need_value() { [[ "$1" -ge 2 ]] || { log_error "Option '$2' needs a value (e.g. $3)."; exit 1; }; }
while [[ $# -gt 0 ]]; do
  case "$1" in
    -l|--lesson)  need_value "$#" "$1" "-l 1"; LESSON="$2"; shift 2 ;;
    -l*)          LESSON="${1#-l}"; shift ;;
    --lang)       need_value "$#" "$1" "--lang python"; LANG_CHOICE="$2"; LANG_EXPLICIT=1; shift 2 ;;
    --lang=*)     LANG_CHOICE="${1#*=}"; LANG_EXPLICIT=1; shift ;;
    -h|--help)    usage; exit 0 ;;
    --)           shift; break ;;
    *)            break ;;
  esac
done

if [[ -z "$LESSON" ]]; then
  if [[ $# -eq 0 || "${1:-}" == "list" ]]; then
    list_lessons
    exit 0
  fi
  log_error "Which lesson? Try:  ./run -l 1   (or:  ./run list)"
  echo
  usage
  exit 1
fi

# Validate the lesson number up front. Unknown-but-numeric lessons are reported
# later by the registry dispatch (which knows what actually exists).
if ! [[ "$LESSON" =~ ^[0-9]+$ ]]; then
  log_error "Lesson must be a number, e.g.  ./run -l 1"
  exit 1
fi

# Polyglot (Option B): Python is the reference; Node.js and C# are opt-in per lesson.
# Use ${x-python} (no colon) so an explicit but empty --lang= errors instead of
# silently defaulting to Python.
case "${LANG_CHOICE-python}" in
  py|python)        LANG_CHOICE=python ;;
  js|node|nodejs)   LANG_CHOICE=node ;;
  cs|csharp|dotnet) LANG_CHOICE=csharp ;;
  *) log_error "Unknown --lang '${LANG_CHOICE}'. Use: python | node | csharp"; exit 1 ;;
esac
# Lessons 1-2 are ported under node/lesson-N and dotnet/lesson-N (legacy layout).
# Lessons 3+ carry their own language dispatch in lesson.json, so they skip this.
if [[ "$LANG_CHOICE" != "python" && ( "$LESSON" == "1" || "$LESSON" == "2" ) ]]; then
  impl_dir="$ROOT_DIR/${LANG_CHOICE/csharp/dotnet}/lesson-${LESSON}"
  # Invoke via bash (not requiring the exec bit) so it works on Windows/Git Bash too.
  if [[ -f "$impl_dir/run.sh" ]]; then
    log_info "Running the ${LANG_CHOICE} implementation of Lesson ${LESSON} ..."
    exec bash "$impl_dir/run.sh" "$@"
  fi
  # Not ported yet: exit non-zero so callers/CI don't mistake this for a successful run.
  log_warn "The ${LANG_CHOICE} implementation of Lesson ${LESSON} is not available yet."
  log_info  "Run the Python reference instead:  ./run -l ${LESSON}    (see INSTALL.md)"
  exit 3
fi

ACTION="${1:-}"
[[ $# -gt 0 ]] && shift || true

run_lesson_1() {
  ensure_venv
  case "${ACTION:-web}" in
    web|"")
      announce_provider
      local port; port="$(find_free_port "${WEB_PORT:-5000}")"
      log_info "Lesson 1 · RAG web UI → http://127.0.0.1:${port}    (Ctrl-C to stop)"
      exec "$PYTHON_BIN" -m localrag web --port "$port"
      ;;
    ask)
      announce_provider
      exec "$PYTHON_BIN" -m localrag ask "$@"
      ;;
    repl)
      announce_provider
      exec "$PYTHON_BIN" -m localrag ask
      ;;
    index)
      exec "$PYTHON_BIN" -m localrag index --reindex
      ;;
    test)
      exec "$PYTHON_BIN" -m pytest -q "$ROOT_DIR/tests/test_smoke.py"
      ;;
    *)
      log_error "Lesson 1 actions:  web | ask \"q\" | repl | index | test"
      exit 1
      ;;
  esac
}

run_lesson_2() {
  ensure_venv
  case "${ACTION:-demo}" in
    demo|"")
      log_info "Lesson 2 · MCP — spawning the server over stdio and calling its tools ..."
      exec "$PYTHON_BIN" "$ROOT_DIR/examples/mcp_demo.py" "$@"
      ;;
    serve)
      log_info "Lesson 2 · MCP server over stdio (a host/client connects to this; Ctrl-C to stop)."
      exec "$PYTHON_BIN" "$ROOT_DIR/mcp_server.py"
      ;;
    register)
      command -v claude >/dev/null 2>&1 || { log_error "The 'claude' CLI is not on your PATH."; exit 1; }
      log_info "Registering the MCP server with Claude Code ..."
      exec claude mcp add local-ai-lab-docs -- "$PYTHON_BIN" "$ROOT_DIR/mcp_server.py"
      ;;
    test)
      exec "$PYTHON_BIN" -m pytest -q "$ROOT_DIR/tests/test_mcp.py"
      ;;
    *)
      log_error "Lesson 2 actions:  demo | serve | register | test"
      exit 1
      ;;
  esac
}

# Lessons 3+: config-driven. Find lessons/NN-*/lesson.json and delegate to the
# lesson engine (run an action, or `show` to walk through the elements). Falls
# back to a legacy LESSON<N>.md written guide when no config-driven lesson exists.
run_registry_lesson() {
  local n2 dir="" g langargs=()
  n2="$(printf '%02d' "$LESSON" 2>/dev/null || echo "$LESSON")"
  for g in "$ROOT_DIR"/lessons/"${n2}"-*/lesson.json "$ROOT_DIR"/lessons/"${LESSON}"-*/lesson.json; do
    [[ -f "$g" ]] && { dir="$(dirname "$g")"; break; }
  done
  [[ $LANG_EXPLICIT -eq 1 ]] && langargs=(--lang "$LANG_CHOICE")

  if [[ -n "$dir" ]]; then
    case "${ACTION:-}" in
      show)    exec "$PYTHON_BIN" "$ROOT_DIR/tools/lesson.py" show    "$LESSON" ${langargs[@]+"${langargs[@]}"} "$@" ;;
      preview) exec "$PYTHON_BIN" "$ROOT_DIR/tools/lesson.py" preview "$LESSON" ${langargs[@]+"${langargs[@]}"} ;;
      *)       exec "$PYTHON_BIN" "$ROOT_DIR/tools/lesson.py" run     "$LESSON" ${ACTION:+"$ACTION"} ${langargs[@]+"${langargs[@]}"} "$@" ;;
    esac
  fi

  if [[ -f "$ROOT_DIR/LESSON${LESSON}.md" ]]; then
    log_info "Lesson ${LESSON} is a written guide (no runnable code yet)."
    log_info "Read it:  LESSON${LESSON}.md   ·   live:  https://nikolareljin.github.io/local-ai-lab/"
    return 0
  fi
  log_error "Unknown lesson '${LESSON}'. Try:  ./run list"
  exit 1
}

case "$LESSON" in
  1) run_lesson_1 "$@" ;;
  2) run_lesson_2 "$@" ;;
  *) run_registry_lesson "$@" ;;
esac
